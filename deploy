maven-deploy.yml:
---
- name: Deploy Maven Web Application
  hosts: appserver
  become: yes

  tasks:

    - name: Stop Tomcat
      shell: /opt/tomcat/bin/shutdown.sh
      ignore_errors: yes

    - name: Remove old deployment
      file:
        path: "{{ item }}"
        state: absent
      loop:
        - /opt/tomcat/webapps/ROOT
        - /opt/tomcat/webapps/ROOT.war

    - name: Copy WAR to Tomcat
      copy:
        src: /var/lib/jenkins/workspace/MavenWebApp/target/maven-web-application.war
        dest: /opt/tomcat/webapps/ROOT.war
        mode: '0644'

    - name: Start Tomcat
      shell: /opt/tomcat/bin/startup.sh

    - name: Wait for port 8080
      wait_for:
        port: 8080
        delay: 10
        timeout: 60
